[23.791452, "o", "# Menu de opciones para proyecto Rust\r\n# [Ctrl+q] Salir\r\n# [tab] Buscar\r\n# [<-|->] Navegar\r\n\"Rust Project\":\r\n  Información:\r\n    \"Versión de cargo\": cargo --version\r\n    \"Versión de rust\": rustc --version\r\n  Desarrollo:\r\n    Ejecutar: cargo run\r\n    Compilar: cargo build\r\n    Check: cargo check\r\n    \"Ver Errores (Watch)\": cargo watch -x check\r\n  \"Release y Distribución\":\r\n    \"Build Optimizado\": cargo build --release\r\n    \"Instalar Binario\": cargo install --path .\r\n    \"Empaquetar Crates\": cargo package\r\n    \"Publicar (Dry Run)\": cargo publish --dry-run\r\n  \"Testeo y Calidad\":\r\n    \"Tests Unitarios\": cargo test\r\n    \"Linter (Clippy)\": cargo clippy\r\n    Formatear: cargo fmt\r\n    \"Seguridad (Audit)\": cargo audit\r\n  Documentación:\r\n    \"Generar Docs\": cargo doc\r\n    \"Ver en Navegador\": cargo doc --open\r\n    \"Limpiar Documentación\": rm -rf target/doc\r\n  Limpieza:\r\n    Clean: cargo clean\r\n    \"Reset Cargo\": cargo clean && cargo update\r\n    # Eliminar el lock file\r\n    \"Eliminar Lockfile\": rm Cargo.lock\r\n\u001b[7mtmenu.toon (END)\u001b[27m\u001b[K"]
